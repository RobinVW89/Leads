---
import { SITE_CONFIG } from '../config/site';
import '../styles/theme.css';

type Crumb = {
	label: string;
	href?: string;
};

type Props = {
	title: string;
	description: string;
	canonicalPath?: string;
	breadcrumbs?: Crumb[];
	jsonLd?: object | object[];
	stickyCta?: {
		label: string;
		href: string;
		badge?: string;
	};
};

const {
	title,
	description,
	canonicalPath = Astro.url.pathname,
	breadcrumbs = [],
	jsonLd = [],
	stickyCta
} = Astro.props;
const canonicalUrl = new URL(canonicalPath, SITE_CONFIG.siteUrl).toString();
const jsonLdList = Array.isArray(jsonLd) ? jsonLd : [jsonLd];
---

<!doctype html>
<html lang="fr">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<meta name="description" content={description} />
		<link rel="canonical" href={canonicalUrl} />
		<meta property="og:type" content="website" />
		<meta property="og:locale" content="fr_FR" />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:url" content={canonicalUrl} />
		<meta property="og:site_name" content={SITE_CONFIG.siteName} />
		<!-- Google tag (gtag.js) -->
		<script async src="https://www.googletagmanager.com/gtag/js?id=G-D2Y7CDBF3X"></script>
		<script is:inline>
			window.dataLayer = window.dataLayer || [];
			function gtag() {
				dataLayer.push(arguments);
			}
			gtag('js', new Date());

			gtag('config', 'G-D2Y7CDBF3X');
		</script>
		{jsonLdList.map((entry) => (
			<script type="application/ld+json" set:html={JSON.stringify(entry)} />
		))}
	</head>
	<body>
		<a href="#contenu" class="skip-link">Aller au contenu principal</a>
		<header class="site-header">
			<div class="container inner">
				<a class="brand" href="/">{SITE_CONFIG.siteName}</a>
				<nav class="top-nav" aria-label="Navigation principale">
					<a href="/#metiers">Métiers</a>
					<a href="/comment-ca-marche">Comment ça marche</a>
					<a href={SITE_CONFIG.resonanceUrl} target="_blank" rel="noopener noreferrer">Espace pros</a>
					<a href="/politique-confidentialite">Confidentialité</a>
					<a href="/mentions-legales">Mentions légales</a>
				</nav>
				<a class="tel-link" href={`tel:${SITE_CONFIG.telContactHref}`}>
					{SITE_CONFIG.telContact}
				</a>
			</div>
		</header>
		<main class="container" id="contenu">
			{breadcrumbs.length > 0 && (
				<nav class="breadcrumbs" aria-label="Fil d'Ariane">
					{breadcrumbs.map((crumb, index) => (
						<>
							{index > 0 && ' / '}
							{crumb.href ? <a href={crumb.href}>{crumb.label}</a> : <span>{crumb.label}</span>}
						</>
					))}
				</nav>
			)}
			<slot />
		</main>
		<footer class="footer">
			<div class="container">
				<div class="footer-grid">
					<div>
						<p>
							{SITE_CONFIG.siteName} • Mise en relation gratuite avec des professionnels locaux vérifiés dans
							l'Yonne.
						</p>
						<p>
							<a href="/comment-ca-marche">Comment ça marche</a> • <a href="/mentions-legales">Mentions légales</a>{' '}
							• <a href="/politique-confidentialite">Politique de confidentialité</a>
						</p>
					</div>
					<div>
						<p class="footer-column-title">Nos pros à Auxerre</p>
						<p class="footer-links">
							<a href="/auxerre/">Hub Auxerre</a>
							<a href="/plombier-chauffagiste/auxerre/">Plombier</a>
							<a href="/climatisation-pompe-a-chaleur/auxerre/">Climatisation</a>
							<a href="/electricien/auxerre/">Électricien</a>
							<a href="/couvreur/auxerre/">Couvreur</a>
							<a href="/menuisier-portail-fenetre/auxerre/">Menuisier</a>
							<a href="/isolation/auxerre/">Isolation</a>
							<a href="/estimation-immobiliere/auxerre/">Estimation</a>
							<a href="/courtier-credit-assurance/auxerre/">Courtier</a>
						</p>
					</div>
					<div>
						<p class="footer-column-title">Espace pros</p>
						<p>
							<a href={SITE_CONFIG.resonanceUrl} target="_blank" rel="noopener noreferrer">Vous êtes artisan ? Rejoignez Résonance</a>
						</p>
					</div>
				</div>
			</div>
		</footer>
		{stickyCta && (
			<div class="mobile-sticky-cta" role="region" aria-label="Action rapide">
				{stickyCta.badge && <span>{stickyCta.badge}</span>}
				<a class="btn" href={stickyCta.href}>{stickyCta.label}</a>
			</div>
		)}
	</body>
</html>

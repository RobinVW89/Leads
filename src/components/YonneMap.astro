---
import type { Ville } from '../lib/data';

type Props = {
  villes: Ville[];
  metierSlug?: string;
  selectedVilleSlug?: string;
};

const { villes: _villes, metierSlug: _metierSlug = 'plombier-chauffagiste', selectedVilleSlug: _selectedVilleSlug = '' } = Astro.props;
---

<div class="yonne-map">
  <p class="map-title">Carte locale de l'Yonne</p>
  <div
    class="yonne-map-canvas"
    role="img"
    aria-label="Département de l'Yonne"
  ></div>
</div>

---
import Layout from '../layouts/Layout.astro';
import { SITE_CONFIG } from '../config/site';

const title = 'Mentions légales | Travaux & Pros de l\'Yonne';
const description = 'Informations légales du portail Travaux & Pros de l\'Yonne.';
const breadcrumbs = [
  { label: 'Accueil', href: '/' },
  { label: 'Mentions légales' }
];
---

<Layout title={title} description={description} breadcrumbs={breadcrumbs} canonicalPath="/mentions-legales">
  <section class="section">
    <h1 class="page-title">Mentions legales</h1>
    <div class="legal-stack">
    <article class="rule-block">
      <h2>Éditeur du site</h2>
      <p>
        {SITE_CONFIG.siteName}<br />
        Responsable de publication : à compléter<br />
        Adresse postale : à compléter<br />
        Contact : <a href={`mailto:${SITE_CONFIG.contactEmail}`}>{SITE_CONFIG.contactEmail}</a><br />
        Téléphone : <a href={`tel:${SITE_CONFIG.telContactHref}`}>{SITE_CONFIG.telContact}</a>
      </p>
    </article>

    <article class="rule-block">
      <h2>Hébergement</h2>
      <p>
        Site hébergé sur Cloudflare Pages.<br />
        Cloudflare, Inc. - 101 Townsend St, San Francisco, CA 94107, USA.
      </p>
    </article>

    <article class="rule-block">
      <h2>Objet du service</h2>
      <p>
        Ce site propose un service de mise en relation entre particuliers et professionnels locaux de l'Yonne dans
        le cadre d'une demande de devis.
      </p>
    </article>

    <article class="rule-block">
      <h2>Propriété intellectuelle</h2>
      <p>
        L'ensemble des contenus du site (textes, structure, éléments graphiques) est protégé par le droit d'auteur.
        Toute reproduction, adaptation ou diffusion sans autorisation préalable est interdite, sauf usage strictement
        privé.
      </p>
    </article>

    <article class="rule-block">
      <h2>Responsabilité</h2>
      <p>
        Les informations publiées sont fournies à titre indicatif. L'éditeur ne peut être tenu responsable d'une
        indisponibilité temporaire du service, ni des suites données par les professionnels après la mise en relation.
      </p>
    </article>
    </div>
  </section>
</Layout>

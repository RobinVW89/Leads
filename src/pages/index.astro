---
import Layout from '../layouts/Layout.astro';
import ReassuranceBadges from '../components/ReassuranceBadges.astro';
import MetierIcon from '../components/MetierIcon.astro';
import YonneMap from '../components/YonneMap.astro';
import { SITE_CONFIG } from '../config/site';
import { metiersData, villesData } from '../lib/data';

const title = `${SITE_CONFIG.siteName} | Devis gratuit dans l'Yonne`;
const description = SITE_CONFIG.tagline;
const metiersActifs = metiersData.filter((metier) => metier.actif).length;
const metiersBientot = metiersData.filter((metier) => !metier.actif).length;
const getMetierScore = (metier: (typeof metiersData)[number]) =>
	(metier.slug === 'veranda-pergola-store' ? 300 : 0) + (metier.saison !== 'toute-annee' ? 100 : 0) + (metier.actif ? 10 : 0);
const metiersEnAvant = [...metiersData].sort((a, b) => {
	return getMetierScore(b) - getMetierScore(a);
});
const defaultMetier = metiersEnAvant.find((metier) => metier.actif) ?? metiersEnAvant[0];

const organizationSchema = {
	'@context': 'https://schema.org',
	'@type': 'Organization',
	name: SITE_CONFIG.siteName,
	url: SITE_CONFIG.siteUrl,
	description: SITE_CONFIG.description,
	telephone: SITE_CONFIG.telContact,
	areaServed: 'Yonne'
};
---

<Layout title={title} description={description} jsonLd={organizationSchema}>
	<section class="hero">
		<div class="editorial-grid">
			<article class="hero-main">
				<span class="eyebrow">Portail local Yonne 89</span>
				<h1>Décrivez vos travaux. On vous rappelle sous 24 h.</h1>
				<p>
					Partout dans l'Yonne, vous trouvez le bon professionnel local selon votre métier, votre ville et votre
					délai. Sans engagement, sans promesse marketing exagérée.
				</p>
				<div class="hero-actions">
					<a class="btn" href="#quick-access">Démarrer ma demande</a>
					<span class="inline-note">Réponse sous 24 h</span>
				</div>
				<ReassuranceBadges />
				<div class="pill-list" aria-label="Indicateurs de couverture locale">
					<span class="pill">{metiersActifs} métiers ouverts</span>
					<span class="pill">{metiersBientot} métiers en préparation</span>
					<span class="pill">{villesData.length} villes couvertes</span>
				</div>
			</article>

			<aside class="signature-panel">
				<YonneMap villes={villesData} metierSlug={defaultMetier.slug} />
			</aside>
		</div>
	</section>

	<section class="section" id="quick-access">
		<div class="panel">
			<h2>Accès rapide à votre page locale</h2>
			<p class="muted">Choisissez votre métier et votre commune pour ouvrir la page utile directement.</p>
			<form id="quick-access-form" class="grid cols-3">
				<div>
					<label for="quick-metier">Métier</label>
					<select id="quick-metier" required>
						<option value="">Choisir un métier</option>
						{metiersData.map((metier) => (
							<option value={metier.slug}>{metier.nom}</option>
						))}
					</select>
				</div>
				<div>
					<label for="quick-ville">Ville</label>
					<select id="quick-ville">
						<option value="">Voir la page métier générale</option>
						{villesData.map((ville) => (
							<option value={ville.slug}>{ville.nom}</option>
						))}
					</select>
				</div>
				<div style="display: flex; align-items: flex-end; gap: 0.6rem;">
					<button type="submit">Démarrer ma demande</button>
					<span class="inline-note">Réponse sous 24 h</span>
				</div>
			</form>
		</div>
	</section>

	<section class="section" id="metiers">
		<div class="rule-block">
			<h2>Métiers disponibles dans l'Yonne</h2>
			<p class="muted">Chaque fiche locale explique les prestations, les prix indicatifs et les délais de rappel.</p>
		</div>
		<div class="bento-grid">
			{metiersEnAvant.map((metier) => (
				<article
					class={`metier-tile ${metier.saison !== 'toute-annee' ? 'is-seasonal' : ''} ${!metier.actif ? 'is-inactive' : ''}`}
				>
					<a class="tile-main-link" href={`/${metier.slug}/`}>
						<h3>
							<MetierIcon slug={metier.slug} label={metier.nom} />
							<span>{metier.nom}</span>
						</h3>
					</a>
					<p class="muted">{metier.description.slice(0, 130)}...</p>
					<p class="tile-secondary-link"><a href={`/${metier.slug}/auxerre/`}>Voir aussi à Auxerre</a></p>
					<div class="badges">
						{metier.saison === 'ete' && <span class="badge">Forte demande estivale</span>}
						{!metier.actif && <span class="badge">Ouverture prochaine</span>}
						{metier.urgence && <span class="badge">Intervention rapide possible</span>}
					</div>
				</article>
			))}
		</div>
	</section>

	<section class="section" id="comment-marche-home">
		<div class="rule-block">
			<h2>Comment ça marche</h2>
		</div>
		<div class="steps">
			<article class="step reveal-step">
				<h3>01. Décrivez vos travaux</h3>
				<p>Vous renseignez votre besoin, votre commune et votre délai en langage simple.</p>
			</article>
			<article class="step reveal-step">
				<h3>02. Orientation locale</h3>
				<p>Nous transmettons votre demande au professionnel local pertinent selon le métier choisi.</p>
			</article>
			<article class="step reveal-step">
				<h3>03. Échange et devis</h3>
				<p>Le professionnel vous rappelle, confirme les détails et vous propose son devis.</p>
			</article>
		</div>
	</section>

	<section class="section" id="espace-pros">
		<div class="panel pro-network-panel">
			<h2>Vous êtes artisan dans l'Yonne ?</h2>
			<p class="muted">
				Les professionnels présents sur ce site sont issus de notre réseau partenaire Résonance.
				Rejoignez le club pour intégrer les Pros de l'Yonne.
			</p>
			<div class="hero-actions" style="margin-top: 0.2rem;">
				<a class="btn secondary" href={SITE_CONFIG.resonanceUrl} target="_blank" rel="noopener noreferrer">
					Rejoindre Résonance
				</a>
				<span class="inline-note">Ouvert aux pros sérieux du 89</span>
			</div>
		</div>
	</section>

	<script is:inline>
		const quickAccessForm = document.getElementById('quick-access-form');
		const quickCityField = document.getElementById('quick-ville');

		if (quickCityField instanceof HTMLSelectElement) {
			const storedCity = window.localStorage.getItem('selectedVilleSlug') || '';
			if (storedCity) {
				quickCityField.value = storedCity;
			}
		}

		if (quickAccessForm instanceof HTMLFormElement) {
			quickAccessForm.addEventListener('submit', (event) => {
				event.preventDefault();
				const metier = document.getElementById('quick-metier');
				const ville = document.getElementById('quick-ville');

				if (!(metier instanceof HTMLSelectElement) || !(ville instanceof HTMLSelectElement)) {
					return;
				}

				if (!metier.value) {
					return;
				}

				if (ville.value) {
					window.localStorage.setItem('selectedVilleSlug', ville.value);
				}

				const destination = ville.value ? `/${metier.value}/${ville.value}/` : `/${metier.value}/`;
				window.location.href = destination;
			});
		}

		const revealItems = document.querySelectorAll('#comment-marche-home .reveal-step');
		if ('IntersectionObserver' in window && revealItems.length > 0) {
			const observer = new IntersectionObserver(
				(entries) => {
					entries.forEach((entry) => {
						if (entry.isIntersecting) {
							entry.target.classList.add('is-visible');
							observer.unobserve(entry.target);
						}
					});
				},
				{ threshold: 0.28 }
			);

			revealItems.forEach((item) => observer.observe(item));
		}
	</script>
</Layout>

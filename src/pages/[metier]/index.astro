---
import Layout from '../../layouts/Layout.astro';
import LeadForm from '../../components/LeadForm.astro';
import ReassuranceBadges from '../../components/ReassuranceBadges.astro';
import MetierIcon from '../../components/MetierIcon.astro';
import YonneMap from '../../components/YonneMap.astro';
import { getParcoursByMetierSlug, metiersData, villesData, type Metier } from '../../lib/data';

export async function getStaticPaths() {
  return metiersData.map((metier) => ({
    params: { metier: metier.slug },
    props: { metier }
  }));
}

type Props = {
  metier: Metier;
};

const { metier } = Astro.props;
const title = metier.actif
  ? `${metier.nom} dans l'Yonne | Devis gratuit`
  : `${metier.nom} dans l'Yonne | Bientôt disponible`;
const description = metier.actif
  ? `${metier.description} Demandez un devis gratuit et soyez recontacté par un professionnel local de l'Yonne.`
  : `${metier.description} Ce service ouvre bientôt dans l'Yonne, laissez votre email pour être prévenu en premier.`;
const parcours = getParcoursByMetierSlug(metier.slug);
const breadcrumbs = [
  { label: 'Accueil', href: '/' },
  { label: metier.nom }
];
---

<Layout
  title={title}
  description={description}
  breadcrumbs={breadcrumbs}
  canonicalPath={`/${metier.slug}/`}
  stickyCta={{ label: 'Démarrer ma demande', href: '#devis', badge: 'Réponse sous 24 h' }}
>
  <section class="section">
    <div class="editorial-grid">
      <article class="hero-main">
        <span class="eyebrow">Métier local Yonne</span>
        <h1>{metier.nom} dans l'Yonne</h1>
        <p>{metier.description}</p>
        <div class="hero-actions">
          <a class="btn" href="#devis">Démarrer ma demande</a>
          <span class="inline-note">Réponse sous 24 h</span>
        </div>
        <ReassuranceBadges />
        {metier.urgence && <p class="badge" style="margin-top: 0.8rem;">Intervention rapide possible selon disponibilité locale.</p>}
      </article>
      <aside class="signature-panel">
        <YonneMap villes={villesData} metierSlug={metier.slug} />
      </aside>
    </div>
  </section>

  <section class="section">
    <div class="grid cols-2 rule-block">
      <article>
        <h2>Prestations courantes</h2>
        <ul>
          {metier.prestations.map((prestation) => (
            <li>{prestation}</li>
          ))}
        </ul>
      </article>
      <article>
        <h2>Fourchettes de prix indicatives</h2>
        <p>{metier.fourchettePrix}</p>
      </article>
    </div>
  </section>

  <section class="section">
    <div class="rule-block">
      <h2>Questions fréquentes</h2>
    </div>
    <div class="grid cols-2">
      {metier.questionsFrequentes.map((faq) => (
        <article class="step">
          <h3>{faq.question}</h3>
          <p>{faq.reponse}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="section" id="devis">
    <LeadForm metier={metier.slug} metierNom={metier.nom} actif={metier.actif} />
  </section>

  {parcours && (
    <section class="section">
      <div class="rule-block">
        <h2>Parcours de demande</h2>
      </div>
      <p class="muted">
        Voici les informations qui vous seront demandées pour qualifier efficacement votre besoin en {metier.nom.toLowerCase()}.
      </p>
      <div class="steps">
        {parcours.etapes.map((etape, index) => (
          <article class="step">
            <h3>
              Étape {index + 1} : {etape.question}
            </h3>
            <p>{etape.options.join(' / ')}</p>
            {etape.facultatif && <p class="muted">Champ facultatif.</p>}
          </article>
        ))}
      </div>
    </section>
  )}

  {!metier.actif && (
    <section class="section">
      <article class="rule-block">
        <h2>Ouverture prochaine</h2>
        <p>
          Ce service est en préparation dans l'Yonne. Vous pouvez déjà laisser votre email pour être prévenu en
          priorité dès l'ouverture.
        </p>
      </article>
    </section>
  )}

  <section class="section">
    <div class="rule-block">
      <h2>Nos pages locales dans l'Yonne</h2>
    </div>
    <div class="bento-grid">
      {villesData.map((ville) => (
        <a href={`/${metier.slug}/${ville.slug}/`} class="metier-tile">
          <h3>
            <MetierIcon slug={metier.slug} />
            <span>{metier.nom} à {ville.nom}</span>
          </h3>
          <p class="muted">{ville.codePostal} • {ville.population}</p>
        </a>
      ))}
    </div>
  </section>
</Layout>

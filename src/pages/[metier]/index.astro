---
import Layout from '../../layouts/Layout.astro';
import LeadForm from '../../components/LeadForm.astro';
import ReassuranceBadges from '../../components/ReassuranceBadges.astro';
import { getParcoursByMetierSlug, metiersData, villesData, type Metier } from '../../lib/data';

export async function getStaticPaths() {
  return metiersData.map((metier) => ({
    params: { metier: metier.slug },
    props: { metier }
  }));
}

type Props = {
  metier: Metier;
};

const { metier } = Astro.props;
const title = metier.actif
  ? `${metier.nom} dans l'Yonne | Devis gratuit`
  : `${metier.nom} dans l'Yonne | Bientot disponible`;
const description = metier.actif
  ? `${metier.description} Demandez un devis gratuit et soyez recontacté par un professionnel local de l'Yonne.`
  : `${metier.description} Ce service ouvre bientot dans l'Yonne, laissez votre email pour etre prevenu en premier.`;
const parcours = getParcoursByMetierSlug(metier.slug);
const breadcrumbs = [
  { label: 'Accueil', href: '/' },
  { label: metier.nom }
];
---

<Layout title={title} description={description} breadcrumbs={breadcrumbs} canonicalPath={`/${metier.slug}/`}>
  <section class="section">
    <h1>{metier.nom} dans l'Yonne</h1>
    <p>{metier.description}</p>
    <ReassuranceBadges />
    {metier.urgence && <p class="badge" style="margin-top: 1rem;">Intervention rapide possible selon disponibilité locale.</p>}
  </section>

  <section class="section">
    <div class="grid cols-2">
      <article class="card">
        <h2>Prestations courantes</h2>
        <ul>
          {metier.prestations.map((prestation) => (
            <li>{prestation}</li>
          ))}
        </ul>
      </article>
      <article class="card">
        <h2>Fourchettes de prix indicatives</h2>
        <p>{metier.fourchettePrix}</p>
      </article>
    </div>
  </section>

  <section class="section">
    <h2>Questions fréquentes</h2>
    <div class="grid cols-2">
      {metier.questionsFrequentes.map((faq) => (
        <article class="card">
          <h3>{faq.question}</h3>
          <p>{faq.reponse}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="section">
    <LeadForm metier={metier.slug} metierNom={metier.nom} actif={metier.actif} />
  </section>

  {parcours && (
    <section class="section">
      <h2>Parcours de demande</h2>
      <p class="muted">
        Voici les informations qui vous seront demandées pour qualifier efficacement votre besoin en {metier.nom.toLowerCase()}.
      </p>
      <div class="grid cols-3">
        {parcours.etapes.map((etape, index) => (
          <article class="card">
            <h3>
              Etape {index + 1} : {etape.question}
            </h3>
            <p>{etape.options.join(' / ')}</p>
            {etape.facultatif && <p class="muted">Champ facultatif.</p>}
          </article>
        ))}
      </div>
    </section>
  )}

  {!metier.actif && (
    <section class="section">
      <article class="card" style="border-left: 4px solid #d97a2b;">
        <h2>Ouverture prochaine</h2>
        <p>
          Ce service est en preparation dans l'Yonne. Vous pouvez deja laisser votre email pour etre prevenu en
          priorite des l'ouverture.
        </p>
      </article>
    </section>
  )}

  <section class="section">
    <h2>Nos pages locales dans l'Yonne</h2>
    <div class="grid cols-3">
      {villesData.map((ville) => (
        <article class="card">
          <h3>
            <a href={`/${metier.slug}/${ville.slug}/`}>{metier.nom} à {ville.nom}</a>
          </h3>
          <p class="muted">{ville.codePostal} • {ville.population}</p>
        </article>
      ))}
    </div>
  </section>
</Layout>

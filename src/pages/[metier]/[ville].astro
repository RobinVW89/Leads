---
import Layout from '../../layouts/Layout.astro';
import LeadForm from '../../components/LeadForm.astro';
import CertificationBadge from '../../components/CertificationBadge.astro';
import ReassuranceBadges from '../../components/ReassuranceBadges.astro';
import MetierIcon from '../../components/MetierIcon.astro';
import RealisationsGallery from '../../components/RealisationsGallery.astro';
import YonneMap from '../../components/YonneMap.astro';
import RelatedServices from '../../components/RelatedServices.astro';
import { getParcoursByMetierSlug, metiersData, villesData, type Metier, type Ville } from '../../lib/data';
import { getLocalizedIntro, getSectionOrder } from '../../lib/content';
import { faqSchema, serviceSchema } from '../../lib/seo';

export async function getStaticPaths() {
  return metiersData.flatMap((metier) =>
    villesData.map((ville) => ({
      params: { metier: metier.slug, ville: ville.slug },
      props: { metier, ville }
    }))
  );
}

type Props = {
  metier: Metier;
  ville: Ville;
};

const { metier, ville } = Astro.props;

const h1 = metier.actif
  ? `${metier.nom} à ${ville.nom} - devis gratuit`
  : `${metier.nom} à ${ville.nom} - bientôt disponible`;
const description = metier.actif
  ? `${metier.nom} à ${ville.nom} (${ville.codePostal}). ${ville.phraseLocale} Mise en relation gratuite avec un professionnel local.`
  : `${metier.nom} à ${ville.nom} (${ville.codePostal}). ${ville.phraseLocale} Ce service ouvre bientôt dans l'Yonne avec inscription prioritaire par email.`;
const intro = getLocalizedIntro(metier, ville);
const sectionOrder = getSectionOrder(metier.slug, ville.slug);
const parcours = getParcoursByMetierSlug(metier.slug);
const nearby = ville.quartiersOuCommunesProches.join(', ');
const canonicalPath = `/${metier.slug}/${ville.slug}/`;

const breadcrumbs = [
  { label: 'Accueil', href: '/' },
  { label: metier.nom, href: `/${metier.slug}/` },
  { label: ville.nom }
];

const schemas = [serviceSchema(metier, ville, canonicalPath), faqSchema(metier)];
---

<Layout
  title={h1}
  description={description}
  canonicalPath={canonicalPath}
  breadcrumbs={breadcrumbs}
  jsonLd={schemas}
  stickyCta={{ label: 'Démarrer ma demande', href: '#devis', badge: 'Réponse sous 24 h' }}
>
  <section class="section">
    <div class="editorial-grid">
      <article class="hero-main">
        <span class="eyebrow">Page locale {ville.codePostal}</span>
        <h1 class="page-title">{h1}</h1>
        <p class="muted">{ville.codePostal} • {ville.population}</p>
        <p>{ville.phraseLocale}</p>
        <div class="hero-actions">
          <a class="btn" href="#devis">Démarrer ma demande</a>
          <span class="inline-note">Réponse sous 24 h</span>
        </div>
      </article>
      <aside class="signature-panel">
        <YonneMap villes={villesData} metierSlug={metier.slug} selectedVilleSlug={ville.slug} />
      </aside>
    </div>
  </section>
  {
    sectionOrder.map((sectionKey) => (
      <>
        {sectionKey === 'presentation' && (
          <section class="section" id="presentation">
            <div class="rule-block">
              <h2>{metier.nom} à {ville.nom}</h2>
            </div>
            <p>{intro}</p>
            <p class="muted">
              Zone couverte autour de {ville.nom} : {nearby}.
            </p>
            <CertificationBadge certifications={metier.certifications} />
            {metier.saison === 'ete' && <p class="badge">Forte demande pendant la saison estivale.</p>}
            {metier.urgence && <p class="badge">Intervention rapide possible pour les demandes urgentes.</p>}
            <div style="margin-top: 1rem;">
              <ReassuranceBadges />
            </div>
          </section>
        )}
        {sectionKey === 'prestations' && (
          <section class="section" id="prestations">
            <article class="rule-block">
              <h2>Prestations à {ville.nom}</h2>
              <ul>
                {metier.prestations.map((prestation) => (
                  <li>{prestation}</li>
                ))}
              </ul>
            </article>
          </section>
        )}
        {sectionKey === 'tarifs' && (
          <section class="section" id="tarifs">
            <article class="rule-block">
              <h2>Prix indicatifs dans le secteur de {ville.nom}</h2>
              <p>{metier.fourchettePrix}</p>
              <p class="muted">
                Les montants sont donnés à titre indicatif et varient selon l'état du bien et la nature précise du
                chantier.
              </p>
            </article>
          </section>
        )}
        {sectionKey === 'faq' && (
          <section class="section" id="faq">
            <div class="rule-block">
              <h2>Questions fréquentes</h2>
            </div>
            <div class="grid cols-2">
              {metier.questionsFrequentes.map((faq) => (
                <article class="step">
                  <h3>{faq.question}</h3>
                  <p>{faq.reponse}</p>
                </article>
              ))}
            </div>
          </section>
        )}
        {sectionKey === 'realisations' && (
          <RealisationsGallery metierSlug={metier.slug} metierNom={metier.nom} villeNom={ville.nom} />
        )}
        {sectionKey === 'formulaire' && (
          <section class="section" id="devis">
            <LeadForm metier={metier.slug} metierNom={metier.nom} ville={ville.nom} actif={metier.actif} />
          </section>
        )}
      </>
    ))
  }
  {parcours && (
    <section class="section">
      <div class="rule-block">
        <h2>Parcours de qualification prévu</h2>
      </div>
      <p class="muted">
        Pour une demande en {metier.nom.toLowerCase()} à {ville.nom}, nous structurons la prise d'informations en
        plusieurs étapes simples.
      </p>
      <div class="steps">
        {parcours.etapes.map((etape, index) => (
          <article class="step">
            <h3>
              Étape {index + 1} : {etape.question}
            </h3>
            <p>{etape.options.join(' / ')}</p>
            {etape.facultatif && <p class="muted">Champ facultatif.</p>}
          </article>
        ))}
      </div>
    </section>
  )}

  <RelatedServices metierSlug={metier.slug} />

  <section class="section">
    <div class="rule-block">
      <h2>Explorer d'autres communes</h2>
    </div>
    <div class="bento-grid">
      {villesData
        .filter((item) => item.slug !== ville.slug)
        .slice(0, 8)
        .map((item) => (
          <a href={`/${metier.slug}/${item.slug}/`} class="metier-tile">
            <h3>
              <MetierIcon slug={metier.slug} />
              <span>{metier.nom} à {item.nom}</span>
            </h3>
            <p class="muted">{item.codePostal}</p>
          </a>
        ))}
    </div>
  </section>
</Layout>

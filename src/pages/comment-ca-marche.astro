---
import Layout from '../layouts/Layout.astro';

const title = 'Comment ça marche | Travaux & Pros de l\'Yonne';
const description = 'Découvrez le fonctionnement de notre service de mise en relation locale dans l\'Yonne.';
const breadcrumbs = [
  { label: 'Accueil', href: '/' },
  { label: 'Comment ça marche' }
];
---

<Layout title={title} description={description} breadcrumbs={breadcrumbs} canonicalPath="/comment-ca-marche">
  <section class="section">
    <h1 class="page-title">Comment ça marche</h1>
    <p class="muted">Un parcours simple, utile et local pour recevoir une réponse claire sur vos travaux.</p>
    <div class="steps" id="comment-marche-steps">
      <article class="step reveal-step">
        <h2>1. Vous décrivez vos travaux</h2>
        <p>Vous indiquez votre métier, votre commune et le contexte. Le formulaire reste court et lisible.</p>
      </article>
      <article class="step reveal-step">
        <h2>2. Votre demande est orientée</h2>
        <p>Nous envoyons les informations au professionnel local adapté, selon votre besoin réel.</p>
      </article>
      <article class="step reveal-step">
        <h2>3. Vous êtes rappelé</h2>
        <p>Le professionnel vous rappelle pour préciser les travaux et proposer son devis sans engagement.</p>
      </article>
    </div>
  </section>

  <script is:inline>
    const steps = document.querySelectorAll('#comment-marche-steps .reveal-step');
    if ('IntersectionObserver' in window && steps.length > 0) {
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add('is-visible');
              observer.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.22 }
      );

      steps.forEach((step) => observer.observe(step));
    }
  </script>
</Layout>

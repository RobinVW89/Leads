---
import Layout from '../layouts/Layout.astro';

const title = 'Comment ça marche | Travaux & Pros de l\'Yonne';
const description = 'Découvrez le fonctionnement de notre service de mise en relation locale dans l\'Yonne.';
const breadcrumbs = [
  { label: 'Accueil', href: '/' },
  { label: 'Comment ça marche' }
];
---

<Layout title={title} description={description} breadcrumbs={breadcrumbs} canonicalPath="/comment-ca-marche">
  <section class="section">
    <h1>Comment ça marche</h1>
    <div class="grid cols-3">
      <article class="card">
        <h2>1. Votre demande</h2>
        <p>Vous remplissez un formulaire selon votre besoin : métier, commune, délai, description.</p>
      </article>
      <article class="card">
        <h2>2. Orientation locale</h2>
        <p>Votre demande est orientée vers le professionnel local concerné selon le métier sélectionné.</p>
      </article>
      <article class="card">
        <h2>3. Prise de contact</h2>
        <p>Le professionnel vous recontacte pour qualifier le besoin et proposer un devis sans engagement.</p>
      </article>
    </div>
  </section>
</Layout>
